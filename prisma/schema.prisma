generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  GERENTE_GENERAL
  ADMINISTRACION
  VENTAS
  CISO
  ANALISTA_SEGURIDAD
  DESARROLLADOR
  ESPECIALISTA_REDES
  PENTESTER
  SOPORTE_TECNICO
  AUDITOR
  CAPACITADOR
}

enum Area {
  GERENCIA
  ADMINISTRACION
  COMERCIAL
  SISTEMAS
  AUDITORIA
  CAPACITACION
}

model Cliente {
  id             String     @id @default(cuid())
  razonSocial    String     @map("razon_social")
  cuit           String     @unique
  emailContacto  String?    @map("email_contacto")
  telefono       String?
  direccion      String?
  sector         String?
  activo         Boolean    @default(true)
  fechaRegistro  DateTime   @default(now()) @map("fecha_registro")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  proyectos      Proyecto[]

  @@map("clientes")
}

model Servicio {
  id          String     @id @default(cuid())
  nombre      String     @unique
  descripcion String?
  precioBase  Decimal?   @map("precio_base")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  proyectos   Proyecto[]

  @@map("servicios")
}

model Proyecto {
  id              String   @id @default(cuid())
  nombre          String
  descripcion     String?
  estado          String   @default("RELEVAMIENTO")
  fechaInicio     DateTime @default(now()) @map("fecha_inicio")
  fechaEstimadaFin DateTime? @map("fecha_estimada_fin")
  fechaEntregaReal DateTime? @map("fecha_entrega_real")
  montoAcordado   Decimal? @map("monto_acordado")
  clienteId       String   @map("cliente_id")
  servicioId      String   @map("servicio_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cliente   Cliente   @relation(fields: [clienteId], references: [id])
  servicio  Servicio  @relation(fields: [servicioId], references: [id])
  propuestas Propuesta[]
  asignaciones Asignacion[]
  tareas    Tarea[]
  hitos     Hito[]
  documentos Documento[]
  informesAuditoria InformeAuditoria[]
  historialEstados HistorialEstado[]
  capacitaciones Capacitacion[]
  hallazgosPentesting HallazgoPentesting[]
  ticketsSoporte TicketSoporte[]

  @@map("proyectos")
}

model HistorialEstado {
  id            String   @id @default(cuid())
  proyectoId    String   @map("proyecto_id")
  estadoAnterior String? @map("estado_anterior")
  estadoNuevo   String   @map("estado_nuevo")
  empleadoId    String?  @map("empleado_id")
  createdAt     DateTime @default(now()) @map("created_at")

  proyecto Proyecto  @relation(fields: [proyectoId], references: [id])
  empleado Empleado? @relation(fields: [empleadoId], references: [id])

  @@map("historial_estados")
}

model Propuesta {
  id              String   @id @default(cuid())
  version         Int      @default(1)
  montoTotal      Decimal  @map("monto_total")
  detalleServicios Json?   @map("detalle_servicios")
  fechaEmision    DateTime @map("fecha_emision")
  fechaVencimiento DateTime @map("fecha_vencimiento")
  estado          String   @default("ENVIADA")
  proyectoId      String   @map("proyecto_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  proyecto Proyecto @relation(fields: [proyectoId], references: [id])

  @@map("propuestas")
}

model Empleado {
  id           String       @id @default(cuid())
  nombre       String
  apellido     String
  email        String       @unique
  password     String
  rol          Rol
  area         Area
  activo       Boolean      @default(true)
  fechaIngreso DateTime     @default(now()) @map("fecha_ingreso")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  asignaciones Asignacion[]
  notificaciones Notificacion[]
  informesAuditoria InformeAuditoria[]
  auditLogs    AuditLog[]
  historialEstados HistorialEstado[]
  hallazgosPentesting HallazgoPentesting[]
  ticketsCreados TicketSoporte[] @relation("CreadorTicket")
  ticketsAsignados TicketSoporte[] @relation("AsignadoTicket")

  @@map("empleados")
}

model Asignacion {
  id             String   @id @default(cuid())
  rolEnProyecto  String   @map("rol_en_proyecto")
  fechaAsignacion DateTime @default(now()) @map("fecha_asignacion")
  proyectoId     String   @map("proyecto_id")
  empleadoId     String   @map("empleado_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  tareas         Tarea[]

  proyecto Proyecto  @relation(fields: [proyectoId], references: [id])
  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@unique([proyectoId, empleadoId])
  @@map("asignaciones")
}

model Tarea {
  id          String       @id @default(cuid())
  titulo      String
  descripcion String?
  estado      String       @default("PENDIENTE")
  prioridad   String       @default("MEDIA")
  fechaLimite DateTime?    @map("fecha_limite")
  proyectoId  String?      @map("proyecto_id")
  asignacionId String?     @map("asignacion_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  documentos  Documento[]

  proyecto   Proyecto?   @relation(fields: [proyectoId], references: [id])
  asignacion Asignacion? @relation(fields: [asignacionId], references: [id])

  @@map("tareas")
}

model Hito {
  id              String    @id @default(cuid())
  nombre          String
  descripcion     String?
  fechaPrevista   DateTime  @map("fecha_prevista")
  fechaReal       DateTime? @map("fecha_real")
  completado      Boolean   @default(false)
  proyectoId      String    @map("proyecto_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  proyecto Proyecto @relation(fields: [proyectoId], references: [id])

  @@map("hitos")
}

model Documento {
  id           String   @id @default(cuid())
  nombreArchivo String  @map("nombre_archivo")
  tipo         String
  url          String
  proyectoId   String?  @map("proyecto_id")
  tareaId      String?  @map("tarea_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  proyecto Proyecto? @relation(fields: [proyectoId], references: [id])
  tarea    Tarea?    @relation(fields: [tareaId], references: [id])

  @@map("documentos")
}

model Notificacion {
  id         String   @id @default(cuid())
  titulo     String
  mensaje    String
  tipo       String
  link       String?
  leida      Boolean  @default(false)
  empleadoId String   @map("empleado_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@map("notificaciones")
}

model InformeAuditoria {
  id                  String   @id @default(cuid())
  proyectoId          String   @map("proyecto_id")
  creadorId           String   @map("creador_id")
  alcance             String
  criteriosAuditoria  String   @map("criterios_auditoria")
  hallazgos           Json     @default("[]")
  noConformidades     Json     @default("[]") @map("no_conformidades")
  observaciones       Json     @default("[]")
  recomendaciones     Json     @default("[]")
  estado              String   @default("BORRADOR")
  fechaEmision        DateTime? @map("fecha_emision")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  proyecto Proyecto @relation(fields: [proyectoId], references: [id])
  creador  Empleado @relation(fields: [creadorId], references: [id])

  @@map("informes_auditoria")
}

model Capacitacion {
  id            String   @id @default(cuid())
  proyectoId    String?  @map("proyecto_id")
  titulo        String
  temario       String
  duracionHoras Int      @map("duracion_horas")
  modalidad     String   @default("PRESENCIAL")
  fechaInicio   DateTime @map("fecha_inicio")
  fechaFin      DateTime? @map("fecha_fin")
  estado        String   @default("PLANIFICADA")
  materiales    String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  proyecto  Proyecto?             @relation(fields: [proyectoId], references: [id])
  asistentes AsistenteCapacitacion[]

  @@map("capacitaciones")
}

model AsistenteCapacitacion {
  id              String   @id @default(cuid())
  capacitacionId  String   @map("capacitacion_id")
  nombreAsistente String   @map("nombre_asistente")
  emailAsistente  String   @map("email_asistente")
  organizacion    String?
  evaluacion      Int?
  completado      Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  capacitacion Capacitacion @relation(fields: [capacitacionId], references: [id])
  certificado  CertificadoCapacitacion?

  @@map("asistentes_capacitacion")
}

model CertificadoCapacitacion {
  id                String   @id @default(cuid())
  asistenteId       String   @unique @map("asistente_id")
  codigoCertificado String   @unique @map("codigo_certificado")
  fechaEmision      DateTime @default(now()) @map("fecha_emision")
  createdAt         DateTime @default(now()) @map("created_at")

  asistente AsistenteCapacitacion @relation(fields: [asistenteId], references: [id])

  @@map("certificados_capacitacion")
}

model HallazgoPentesting {
  id            String   @id @default(cuid())
  proyectoId    String   @map("proyecto_id")
  creadorId     String   @map("creador_id")
  titulo        String
  descripcion   String
  severidad     String   @default("MEDIA")
  evidencia     String?
  recomendacion String?
  estado        String   @default("PENDIENTE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  proyecto Proyecto @relation(fields: [proyectoId], references: [id])
  creador  Empleado @relation(fields: [creadorId], references: [id])

  @@map("hallazgos_pentesting")
}

model TicketSoporte {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  prioridad   String    @default("MEDIA")
  estado      String    @default("ABIERTO")
  categoria   String?
  clienteNombre String? @map("cliente_nombre")
  proyectoId  String?   @map("proyecto_id")
  creadorId   String    @map("creador_id")
  asignadoAId String?   @map("asignado_a_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  proyecto  Proyecto? @relation(fields: [proyectoId], references: [id])
  creador   Empleado  @relation("CreadorTicket", fields: [creadorId], references: [id])
  asignadoA Empleado? @relation("AsignadoTicket", fields: [asignadoAId], references: [id])

  @@map("tickets_soporte")
}

model Configuracion {
  id    String @id @default(cuid())
  clave String @unique
  valor String
  descripcion String?

  @@map("configuracion")
}

model AuditLog {
  id         String    @id @default(cuid())
  accion     String
  entidad    String
  entidadId  String    @map("entidad_id")
  detalle    Json?
  empleadoId String?   @map("empleado_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  empleado Empleado? @relation(fields: [empleadoId], references: [id])

  @@map("audit_logs")
}
